export async function composeSong(file) {
  const form = new FormData();
  form.append("file", file);

  const res = await fetch("/compose", {
    method: "POST",
    body: form
  });

  if (!res.ok) {
    throw new Error("Composition failed");
  }

  return await res.json();
}
import { useState } from "react";
import { composeSong } from "../api";

export default function FileUpload({ onResult }) {
  const [file, setFile] = useState(null);
  const [loading, setLoading] = useState(false);

  const handleUpload = async () => {
    if (!file) return;

    setLoading(true);
    try {
      const result = await composeSong(file);
      onResult(result);
    } catch (err) {
      alert("Error: " + err.message);
    }
    setLoading(false);
  };

  return (
    <div className="upload-box">
      <input
        type="file"
        accept="application/pdf"
        onChange={(e) => setFile(e.target.files[0])}
      />

      <button onClick={handleUpload} disabled={loading}>
        {loading ? "Composing..." : "Compose Song"}
      </button>
    </div>
  );
}
export default function SongResult({ result }) {
  const { musicxml, audio_file_path, instructions } = result;

  return (
    <div className="result-box">
      <h2>Song Generated</h2>

      <h3>Audio</h3>
      <audio controls src={`/download-audio?path=${audio_file_path}`} />

      <h3>MusicXML Output</h3>
      <pre className="xml-box">{musicxml}</pre>

      <h3>Parsed Instructions</h3>
      <pre className="instructions-box">
        {JSON.stringify(instructions, null, 2)}
      </pre>
    </div>
  );
}
