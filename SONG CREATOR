        import pdfplumber

def extract_pdf_text(file_obj):
    """
    file_obj: a file-like object (UploadFile.file from FastAPI)
    """
    with pdfplumber.open(file_obj) as pdf:
        return "\n".join(page.extract_text() or "" for page in pdf.pages)


def parse_instructions(text: str) -> dict:
    """
    Expects a PDF that roughly follows:

    Title:
    Genre:
    Tempo:
    Key:
    Mood:
    Lyrics:
    Song Structure:
    """
    sections = {}
    current = None

    for line in text.splitlines():
        line = line.strip()
        if not line:
            continue

        if line.endswith(":") and len(line) < 40:
            current = line[:-1]
            sections[current] = ""
        elif current:
            sections[current] += line + "\n"

    return sections

             import openai
from config import OPENAI_API_KEY, OPENAI_MODEL

openai.api_key = OPENAI_API_KEY


def build_prompt(instructions: dict) -> str:
    return f"""
You are a professional music composer.

Compose a complete song in valid MusicXML format using these specifications:

Title: {instructions.get('Title', '').strip()}
Genre: {instructions.get('Genre', '').strip()}
Tempo: {instructions.get('Tempo', '').strip()}
Key: {instructions.get('Key', '').strip()}
Mood: {instructions.get('Mood', '').strip()}

Lyrics:
{instructions.get('Lyrics', '').strip()}

Song Structure:
{instructions.get('Song Structure', '').strip()}

Requirements:
- Return ONLY valid MusicXML.
- Include melody and basic harmony.
- Align lyrics with the vocal line where appropriate.
"""


def generate_musicxml(instructions: dict) -> str:
    prompt = build_prompt(instructions)

    response = openai.ChatCompletion.create(
        model=OPENAI_MODEL,
        messages=[
            {"role": "system", "content": "You are a music composition engine."},
            {"role": "user", "content": prompt},
        ],
        temperature=0.7,
    )

    return response.choices[0].message["content"]

             from music21 import converter, midi
import tempfile
import subprocess
import os
from config import SOUNDFONT_PATH


def musicxml_to_midi_bytes(musicxml: str) -> bytes:
    """
    Convert MusicXML string to MIDI bytes using music21.
    """
    score = converter.parseData(musicxml)
    mf = midi.translate.streamToMidiFile(score)
    return mf.writestr()


def midi_bytes_to_mp3(midi_bytes: bytes) -> str:
    """
    Write MIDI bytes to a temp file, render to MP3 using fluidsynth.
    Returns path to generated MP3 file.
    """
    # Write MIDI to temp file
    midi_fd, midi_path = tempfile.mkstemp(suffix=".mid")
    with os.fdopen(midi_fd, "wb") as f:
        f.write(midi_bytes)

    mp3_fd, mp3_path = tempfile.mkstemp(suffix=".mp3")
    os.close(mp3_fd)  # fluidsynth will write to this path

    # Call fluidsynth
    subprocess.run(
        [
            "fluidsynth",
            "-ni",
            SOUNDFONT_PATH,
            midi_path,
            "-F",
            mp3_path,
            "-r",
            "44100",
        ],
        check=True,
    )

    return mp3_path

          from fastapi import FastAPI, UploadFile, File, HTTPException
from fastapi.responses import FileResponse
from pdf_parser import extract_pdf_text, parse_instructions
from composer import generate_musicxml
from audio_renderer import musicxml_to_midi_bytes, midi_bytes_to_mp3

app = FastAPI(title="PDF Song Composer API")


@app.post("/compose")
async def compose_song(file: UploadFile = File(...)):
    """
    Upload a PDF, get MusicXML + MP3 path.
    """
    try:
        text = extract_pdf_text(file.file)
    except Exception as e:
        raise HTTPException(status_code=400, detail=f"Error reading PDF: {e}")

    instructions = parse_instructions(text)

    if not instructions:
        raise HTTPException(status_code=400, detail="No structured instructions found in PDF.")

    musicxml = generate_musicxml(instructions)

    try:
        midi_bytes = musicxml_to_midi_bytes(musicxml)
        mp3_path = midi_bytes_to_mp3(midi_bytes)
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Error rendering audio: {e}")

    return {
        "musicxml": musicxml,
        "audio_file_path": mp3_path,
        "instructions": instructions,
    }


@app.get("/download-audio")
async def download_audio(path: str):
    """
    Simple endpoint to download the generated MP3.
    """
    return FileResponse(path, media_type="audio/mpeg", filename="song.mp3")


